{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/(.*)\\.(css|js|png|jpg|jpeg|gif|svg|ico)",
      "dest": "frontend/static/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "backend/server.js"
    }
  ]
}
